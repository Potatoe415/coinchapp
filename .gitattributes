# Default: normalize to LF in the repo, checkout as-is on all platforms
* text=auto

# Windows scripts: force CRLF on checkout
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Unix scripts: force LF
*.sh text eol=lf

# Binary files: no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
